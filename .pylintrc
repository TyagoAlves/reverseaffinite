[MASTER]
ignore=tests,tools
jobs=4
persistent=no

[MESSAGES CONTROL]
disable=
    C0103,
    C0114,
    C0115,
    C0116,
    C0301,
    C0304,
    C0305,
    C0321,
    C0413,
    C1801,
    E0401,
    E0602,
    E1101,
    E1120,
    R0903,
    R0913,
    R0914,
    R0915,
    R1705,
    W0201,
    W0221,
    W0612,
    W0613,
    W0622,
    W0631,
    W0703,
    W1203,

[REPORTS]
output-format=colorized
score=no

[BASIC]
good-names=i,j,k,x,y,w,h,r,g,b,a,f,p,dx,dy,img,ok

[DESIGN]
max-args=10
max-locals=30
max-statements=100
max-branches=20
max-attributes=30
min-public-methods=0

[FORMAT]
max-line-length=120

[TYPECHECK]
ignored-modules=
    PyQt5,
    PyQt5.QtCore,
    PyQt5.QtGui,
    PyQt5.QtWidgets,
    numpy

[VARIABLES]
dummy-variables-rgx=_|dummy|ignore
